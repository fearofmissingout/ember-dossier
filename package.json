{
  "name": "ember-dossier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "supabase:init": "node scripts/init-supabase.mjs",
    "supabase:sql": "node scripts/print-supabase-sql.mjs",
    "supabase:check": "node scripts/check-supabase-demo.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wrangler": "^4.98.0"
  }
}
